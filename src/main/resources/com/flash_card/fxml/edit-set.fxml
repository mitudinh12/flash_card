                </HBox>
                <TextField fx:id="setNameField" alignment="TOP_LEFT" maxHeight="-Infinity" prefHeight="49.49" prefWidth="768.0" promptText="Enter Set Name" styleClass="set-name" />
                <TextField fx:id="setDescriptionField" alignment="TOP_LEFT" prefHeight="130.0" prefWidth="768.0" promptText="Enter Set Description" styleClass="set-description" />
                <ComboBox fx:id="topicDropDown" prefHeight="49.49" prefWidth="820.0" promptText="Choose Set Topic" styleClass="set-topic-dropdown" />
            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <HBox alignment="CENTER" layoutX="10.0" layoutY="67.0" prefHeight="54.0" prefWidth="816.0" spacing="10.0" VBox.vgrow="NEVER">
