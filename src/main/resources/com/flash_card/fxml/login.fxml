<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="832" prefWidth="1280" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.flash_card.view.auth.LoginViewController">
   <children>
      <ImageView fitHeight="834.0" fitWidth="1275.0">
         <image>
            <Image url="@../assets/backgrounds/banner.jpg" />
         </image>
      </ImageView>
      <VBox spacing="5.0">
         <children>
            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../assets/icons/language.png" />
                     </image>
                  </ImageView>
                  <Label styleClass="menu-text-white" text="%language.label" textFill="WHITE" />
               </children>
            </HBox>
            <ComboBox fx:id="languageComboBox" onAction="#handleLanguageChange" promptText="%language.select" styleClass="combo-box">
               <items>
                  <FXCollections fx:factory="observableArrayList">
                     <String fx:value="English" />
                     <String fx:value="Suomi" />
                     <String fx:value="ภาษาไทย" />
                     <String fx:value="한국인" />
                     <String fx:value="Tiếng Việt" />
                  </FXCollections>
               </items>
               <VBox.margin>
                  <Insets left="20.0" />
               </VBox.margin>
            </ComboBox>
            <VBox alignment="CENTER">
               <Label text="SuperFlash" textAlignment="CENTER" textFill="#1ad102">
                  <font>
                     <Font name="System Bold" size="88.0" />
                  </font>
                  <VBox.margin>
                     <Insets top="150.0" />
                  </VBox.margin>
               </Label>
            </VBox>
            <VBox alignment="CENTER" prefHeight="791.0" prefWidth="1276.0">
               <children>
                  <Label text="%slogan1">
                     <font>
                        <Font name="System Bold" size="46.0" />
                     </font>
                  </Label>
                  <Label text="%slogan2">
                     <font>
                        <Font name="System Bold" size="31.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="20.0" top="5.0" />
                     </VBox.margin>
                  </Label>
                  <Button fx:id="loginButton" alignment="BOTTOM_LEFT" mnemonicParsing="false" onAction="#loginWithGoogle" style="-fx-background-color: #01C729; -fx-background-radius: 15;" text="%loginButton" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="19.0" />
                     </font>
                  </Button>
                  <Label fx:id="countdownLabel" visible="false" />
               </children>
               <padding>
                  <Insets bottom="280.0" />
               </padding>
            </VBox>
         </children>
      </VBox>

   </children>
</StackPane>
