<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.ComboBox?>
<HBox prefHeight="832.0" prefWidth="1280.0" styleClass="home-background" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.flash_card.view.flashcard.EditManyCardsController">
    <children>
        <AnchorPane prefHeight="200.0" prefWidth="200.0">
            <children>
                <Text layoutY="70.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="super-flash-title" text="SuperFlash" textAlignment="CENTER" wrappingWidth="263.72779846191406" />
                <HBox fx:id="home" alignment="CENTER" layoutX="44.0" layoutY="128.0" onMouseClicked="#handleMenuClick" spacing="20.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="29.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../assets/icons/I-home-black.png" />
                            </image>
                        </ImageView>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="menu-text-black" text="%home" />
                    </children>
                </HBox>
                <HBox fx:id="student" alignment="CENTER" layoutX="47.0" layoutY="199.0" onMouseClicked="#handleMenuClick" spacing="20.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="29.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../assets/icons/I-class-white.png" />
                            </image>
                        </ImageView>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="menu-text-white" text="%forStudent" />
                    </children>
                </HBox>
                <HBox fx:id="teacher" alignment="CENTER" layoutX="44.0" layoutY="266.0" onMouseClicked="#handleMenuClick" spacing="20.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="29.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../assets/icons/I-teacher-white.png" />
                            </image>
                        </ImageView>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="menu-text-white" text="%forTeacher" />
                    </children>
                </HBox>
                <HBox fx:id="createFlashcardSet" alignment="CENTER" layoutX="44.0" layoutY="335.0" onMouseClicked="#handleMenuClick" spacing="20.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="29.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../assets/icons/I-create-card-white.png" />
                            </image>
                        </ImageView>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="menu-text-white" text="%createSet" />
                    </children>
                </HBox>
                <VBox layoutX="66.0" layoutY="693.0" spacing="5.0">
                    <children>
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../assets/icons/language.png" />
                                    </image>
                                </ImageView>
                                <Label styleClass="menu-text-white" text="%language.label" textFill="WHITE" />
                            </children>
                        </HBox>
                        <ComboBox fx:id="languageComboBox" promptText="%language.select" styleClass="combo-box" onAction="#handleLanguageChange">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="English" />
                                    <String fx:value="Suomi" />
                                    <String fx:value="ภาษาไทย" />
                                    <String fx:value="한국인" />
                                    <String fx:value="Tiếng Việt" />
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
        <VBox prefHeight="832.0" prefWidth="1025.0">
            <children>
                <HBox prefHeight="2.0" prefWidth="816.0">
                    <Button fx:id="backToHomepage" onAction="#displayHomepage" styleClass="back-home" text="%flashcard.backToHome" />
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="40.0" />
                    </padding>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label fx:id="setName" prefHeight="51.0" prefWidth="665.0" styleClass="page-title" text="FlashcardSet Name">
                            <HBox.margin>
                                <Insets />
                            </HBox.margin>
                        </Label>
                        <Button id="add-flashcard-button" mnemonicParsing="false" onAction="#handleAddCard" prefHeight="42.0" prefWidth="200.0" text="%flashcard.addTitle" textFill="WHITE" />
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                </HBox>
                <HBox alignment="TOP_RIGHT" prefHeight="41.0" prefWidth="816.0">
                    <children>
                        <StackPane prefHeight="100.0" prefWidth="53.0">
                            <children>
                                <ImageView fx:id="backIcon">
                                    <image>
                                        <Image url="@../assets/icons/left-arrow.png" />
                                    </image>
                                </ImageView>
                                <Button fx:id="backButton" mnemonicParsing="false" onAction="#goBack" prefHeight="25.0" prefWidth="35.0" styleClass="back-button" />
                            </children>
                        </StackPane>
                        <StackPane prefHeight="100.0" prefWidth="55.0">
                            <children>
                                <ImageView fx:id="nextIcon">
                                    <image>
                                        <Image url="@../assets/icons/arrow-point-to-right.png" />
                                    </image>
                                </ImageView>
                                <Button fx:id="nextButton" mnemonicParsing="false" onAction="#goNext" prefHeight="25.0" prefWidth="35.0" styleClass="next-button" />
                            </children>
                        </StackPane>
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets left="50.0" />
                    </padding>
                </HBox>
                <VBox fx:id="flashcardsContainer" prefHeight="501.0" prefWidth="816.0" spacing="10.0" />
            </children>
            <padding>
                <Insets left="100.0" right="100.0" top="40.0" />
            </padding>
        </VBox>
    </children>
</HBox>
