<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.ComboBox?>
<HBox prefHeight="832.0" prefWidth="1280.0" styleClass="class-background" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.flash_card.view.studentMode.StudentStudyFlashcardSetController">
    <children>
        <AnchorPane prefHeight="200.0" prefWidth="200.0">
            <children>
                <Text layoutY="70.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="super-flash-title" text="SuperFlash" textAlignment="CENTER" wrappingWidth="263.72779846191406" />
                <HBox fx:id="home" alignment="CENTER" layoutX="44.0" layoutY="128.0" onMouseClicked="#handleMenuClick" spacing="20.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="29.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../assets/icons/I-home-white.png" />
                            </image>
                        </ImageView>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="menu-text-white" text="%home" />
                    </children>
                </HBox>
                <HBox fx:id="student" alignment="CENTER" layoutX="47.0" layoutY="199.0" onMouseClicked="#handleMenuClick" spacing="20.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="29.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../assets/icons/I-class-black.png" />
                            </image>
                        </ImageView>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="menu-text-black" text="%forStudent" />
                    </children>
                </HBox>
                <HBox fx:id="teacher" alignment="CENTER" layoutX="44.0" layoutY="266.0" onMouseClicked="#handleMenuClick" spacing="20.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="29.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../assets/icons/I-teacher-white.png" />
                            </image>
                        </ImageView>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="menu-text-white" text="%forTeacher" />
                    </children>
                </HBox>
                <HBox fx:id="createFlashcardSet" alignment="CENTER" layoutX="44.0" layoutY="335.0" onMouseClicked="#handleMenuClick" spacing="20.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="29.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../assets/icons/I-create-card-white.png" />
                            </image>
                        </ImageView>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="menu-text-white" text="%createSet" />
                    </children>
                </HBox>
                <VBox layoutX="66.0" layoutY="693.0" spacing="5.0">
                    <children>
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../assets/icons/language.png" />
                                    </image>
                                </ImageView>
                                <Label styleClass="menu-text-white" text="%language.label" textFill="WHITE" />
                            </children>
                        </HBox>
                        <ComboBox fx:id="languageComboBox" promptText="%language.select" styleClass="combo-box" onAction="#handleLanguageChange">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="English" />
                                    <String fx:value="Suomi" />
                                    <String fx:value="ภาษาไทย" />
                                    <String fx:value="한국인" />
                                    <String fx:value="Tiếng Việt" />
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
        <VBox prefHeight="832.0" prefWidth="1025.0">
            <padding>
                <Insets left="100.0" right="100.0" top="40.0" />
            </padding>
            <children>
            <HBox alignment="TOP_RIGHT">
               <children>
                  <ImageView fitHeight="25.0" fitWidth="29.0" onMouseClicked="#handleClose" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../assets/icons/icon.png" />
                     </image>
                  </ImageView>
               </children>
               <padding>
                  <Insets bottom="45.0" />
               </padding>
            </HBox>
                <Label fx:id="setName" styleClass="page-title" text="Your Flashcards" />
            <HBox alignment="CENTER" styleClass="index">
               <children>
                  <Label fx:id="index" text="index" textFill="#656565" />
                  <Text fx:id="middleText" fill="#656565" strokeType="OUTSIDE" strokeWidth="0.0" text="/" />
                  <Label fx:id="total" text="total" textFill="#656565" />
               </children>
            </HBox>
            <StackPane>
               <children>
                  <HBox alignment="CENTER_RIGHT" spacing="20.0">
                     <children>
                        <ImageView fx:id="shuffleIcon" fitHeight="39.0" fitWidth="61.0" onMouseClicked="#handleShuffle" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../assets/icons/Shuffle.png" />
                           </image>
                        </ImageView>
                        <ImageView fitHeight="39.0" fitWidth="61.0" onMouseClicked="#handleReset" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../assets/icons/refresh.png" />
                           </image>
                        </ImageView>
                     </children>
                  </HBox>
                  <Text fx:id="instructionText" fill="#047201" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="instruction" text="Click card to flip" textAlignment="CENTER" wrappingWidth="404.55029296875" />
               </children>
            </StackPane>
                <VBox fx:id="flashcardContainer" prefHeight="450.0" prefWidth="816.0">
                </VBox>
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="easyButton" mnemonicParsing="false" onAction="#handleEasy" styleClass="edit-button" text="EASY" textFill="WHITE" />
                  <Button fx:id="hardButton" mnemonicParsing="false" onAction="#handleHard" styleClass="hard-button" text="HARD" textFill="WHITE" />
               </children>
            </HBox>
                <HBox alignment="CENTER" prefHeight="41.0" prefWidth="107.0" spacing="20.0">
                    <children>
                        <StackPane fx:id="backIcon" onMouseClicked="#handleBack" prefHeight="100.0" prefWidth="53.0">
                            <children>
                                <ImageView>
                                    <image>
                                        <Image url="@../assets/icons/left-arrow.png" />
                                    </image>
                                    <viewport>
                                        <Rectangle2D />
                                    </viewport>
                                </ImageView>
                            </children>
                        </StackPane>
                        <StackPane fx:id="nextIcon" onMouseClicked="#handleNext" prefHeight="100.0" prefWidth="55.0">
                            <children>
                                <ImageView>
                                    <image>
                                        <Image url="@../assets/icons/arrow-point-to-right.png" />
                                    </image>
                                </ImageView>
                            </children>
                        </StackPane>
                    </children>
               <padding>
                  <Insets top="20.0" />
               </padding>
                </HBox>
            </children>
        </VBox>
    </children>
</HBox>
