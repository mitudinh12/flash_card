<HBox prefHeight="832.0" prefWidth="1280.0" styleClass="class-background" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.flash_card.view.studentMode.ClassDetailsViewController">
