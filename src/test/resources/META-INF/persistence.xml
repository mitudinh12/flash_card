<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.0">
    <persistence-unit name="test-persistence-unit" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.flash_card.model.entity.User</class>
        <class>com.flash_card.model.entity.FlashcardSet</class>
        <class>com.flash_card.model.entity.Flashcard</class>
        <class>com.flash_card.model.entity.SharedSet</class>
        <properties>
            <!-- H2 In-Memory Database for Testing -->
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <!-- Hibernate Dialect for H2 -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>

            <!-- Auto-create tables for testing -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- Show SQL output for debugging -->
            <property name="hibernate.show_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
