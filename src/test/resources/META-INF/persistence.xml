<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             version="3.0"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    <persistence-unit name="FlashcardMariaDbUnitTest" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.flash_card.model.entity.User</class>
        <class>com.flash_card.model.entity.FlashcardSet</class>
        <class>com.flash_card.model.entity.Flashcard</class>
        <class>com.flash_card.model.entity.SharedSet</class>
        <class>com.flash_card.model.entity.Classroom</class>
        <class>com.flash_card.model.entity.ClassMember</class>
        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mariadb://localhost:3306/flash_card_test"/>
            <property name="jakarta.persistence.jdbc.user" value="appuser_test"/>
            <property name="jakarta.persistence.jdbc.password" value="app_password"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.mariadb.jdbc.Driver"/>
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MariaDBDialect"/>
            <property name="hibernate.show_sql" value="true" />
        </properties>

    </persistence-unit>
</persistence>